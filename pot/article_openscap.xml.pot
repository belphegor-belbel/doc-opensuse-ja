      "--profile <replaceable>xccdf_org.ssgproject.content_profile_stig</replaceable> \\\n"
      "--report report_sle15_stig.html \\\n"
      "/usr/share/xml/scap/ssg/content/ssg-sle15-ds.xml</command>\n"
      ""
msgstr ""

#. Tag: para
#: article_openscap.xml:1170
#, no-c-format
msgid "To evaluate with a specific rule, you can specify the <guilabel>Rule ID</guilabel> using the <option>--rule</option> command option. For example, you can evaluate only with the rule <guilabel>xccdf_org.ssgproject.content_rule_package_aide_installed</guilabel> :"
msgstr ""

#. Tag: screen
#: article_openscap.xml:1175
#, no-c-format
msgid "&prompt.sudo;<command>oscap xccdf eval \\\n"
      "--profile <replaceable>xccdf_org.ssgproject.content_profile_stig</replaceable> \\\n"
