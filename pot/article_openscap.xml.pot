#: article_openscap.xml:315
#, no-c-format
msgid "&prompt.sudo;<command>zypper install openscap-utils scap-security-guide</command>\n"
      ""
msgstr ""

#. Tag: para
#: article_openscap.xml:319
#, no-c-format
msgid "These packages are dependencies for other optional packages discussed below."
msgstr ""

#. Tag: para
#: article_openscap.xml:324
#, no-c-format
msgid "Optionally, install the following packages:"
msgstr ""

#. Tag: para
#: article_openscap.xml:330
#, no-c-format
msgid "<package>scap-workbench</package> : This package provides the SCAP Workbench graphical utility to perform common <systemitem>oscap</systemitem> tasks."
msgstr ""

#. Tag: para
#: article_openscap.xml:335
