msgstr ""

#. Tag: para
#: article_openscap.xml:184
#, no-c-format
msgid "Configuration parameters for each recommendation, if they exist"
msgstr ""

#. Tag: para
#: article_openscap.xml:189
#, no-c-format
msgid "Recommendations to be applied manually"
msgstr ""

#. Tag: para
#: article_openscap.xml:194
#, no-c-format
msgid "Recommendations to be applied automatically"
msgstr ""

#. Tag: para
#: article_openscap.xml:199
#, no-c-format
msgid "Recommendations to be excluded"
msgstr ""

#. Tag: para
#: article_openscap.xml:204
#, no-c-format
msgid "Additional security controls or measures will be implemented to address excluded recommendations"
msgstr ""

#. Tag: para
#: article_openscap.xml:212
#, no-c-format
msgid "Create a test environment that simulates your environment. Use it as a reference before implementing the technology in your real environment. You should consider the following:"
