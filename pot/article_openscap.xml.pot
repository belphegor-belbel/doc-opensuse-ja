#. Tag: title
#: article_openscap.xml:1136
#, no-c-format
msgid "Evaluating with rules"
msgstr ""

#. Tag: para
#: article_openscap.xml:1137
#, no-c-format
msgid "For each rule, we have the following fields:"
msgstr ""

#. Tag: title
#: article_openscap.xml:1143
#, no-c-format
msgid "Rule"
msgstr ""

#. Tag: para
#: article_openscap.xml:1144
#, no-c-format
msgid "For example, <literal>Install AIDE</literal>"
