msgstr ""

#. Tag: para
#: article_openscap.xml:1119
#, no-c-format
msgid "Specifies the <literal>&ssg;</literal> policy file to use. In this example, we use a policy file in the <literal>DataStream</literal> format. To list all available policies, run: <command>ls -1 /usr/share/xml/scap/ssg/content/ssg-*-ds.xml</command> . For more information about a particular policy, run <command>oscap info</command> on the file."
msgstr ""

#. Tag: para
#: article_openscap.xml:1128
#, no-c-format
msgid "The evaluation process usually takes a few minutes, depending on the number of selected rules."
