      "    --profile <replaceable>stig</replaceable><co xml:id=\"co-oscap-eval-profile\"/> \\\n"
      "    --results <replaceable>/tmp/results.xml</replaceable><co xml:id=\"co-oscap-eval-results\"/> \\\n"
      "    --report <replaceable>/tmp/report.html</replaceable><co xml:id=\"co-oscap-eval-report\"/> \\\n"
      "    /usr/share/xml/scap/ssg/content/ssg-sle15-ds.xml<co xml:id=\"co-oscap-eval-ssg\"/>"
