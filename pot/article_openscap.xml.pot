msgid "To evaluate <emphasis>without</emphasis> a specific rule, you can specify to skip the <guilabel>Rule ID</guilabel> using the <option>--skip-rule</option> command option. For example, you can evaluate without the rule <guilabel>xccdf_org.ssgproject.content_rule_package_aide_installed</guilabel> :"
msgstr ""

#. Tag: screen
#: article_openscap.xml:1187
#, no-c-format
msgid "&prompt.sudo;<command>oscap xccdf eval \\\n"
      "--profile <replaceable>xccdf_org.ssgproject.content_profile_stig</replaceable> \\\n"
      "--report report_sle15_stig.html \\\n"
      "--skip-rule <replaceable>xccdf_org.ssgproject.content_rule_package_aide_installed</replaceable> \\\n"
      "/usr/share/xml/scap/ssg/content/ssg-sle15-ds.xml</command>\n"
      ""
