#. Tag: title
#: net_bridge.xml:11
#, no-c-format
msgid "Configuring a network bridge device"
msgstr ""

#. Tag: meta
#: net_bridge.xml:13
#, no-c-format
msgid "Configure network bridge device"
msgstr ""

#. Tag: para
#: net_bridge.xml:19
#, no-c-format
msgid "A network bridge is a virtual link layer (Layer 2) device that connects multiple network segments into a single logical network. The bridge behaves like a virtual network switch, inspecting traffic and forwarding data frames dynamically based on hardware MAC addresses. A common use case for network bridges is virtualization environments (such as KVM or Xen), where physical network interfaces are shared with multiple guest virtual machines."
msgstr ""

#. Tag: para
#: net_bridge.xml:22
#, no-c-format
msgid "Network bridges can be configured either graphically using &yast; or manually by creating configuration files within the <filename class=\"directory\">/etc/sysconfig/network/</filename> directory."
msgstr ""

#. Tag: para
#: net_bridge.xml:25
#, no-c-format
msgid "The preferred method for creating a network bridge interface is using the YaST Network Devices module."
msgstr ""

#. Tag: title
#: net_bridge.xml:29
#, no-c-format
msgid "Creating a bridge interface with &yast;"
msgstr ""

#. Tag: para
#: net_bridge.xml:31
#, no-c-format
msgid "Run <menuchoice><guimenu>&yast;</guimenu> <guimenu>System</guimenu> <guimenu>Network Settings</guimenu></menuchoice> ."
msgstr ""

#. Tag: para
#: net_bridge.xml:37
#, no-c-format
msgid "Use <guimenu>Add</guimenu> and change the <guimenu>Device Type</guimenu> to <guimenu>Bridge</guimenu> . Proceed with <guimenu>Next</guimenu> ."
msgstr ""

#. Tag: para
#: net_bridge.xml:42
#, no-c-format
msgid "Enter an interface name in the <guimenu>Configuration Name</guimenu> field (for example, <literal>br0</literal> ) and click <guimenu>Next</guimenu> ."
msgstr ""

#. Tag: para
#: net_bridge.xml:47
#, no-c-format
msgid "In the <guimenu>Address</guimenu> tab, specify how the network bridge interface obtains its IP configuration (either via <literal>DHCP</literal> or by assigning a <guimenu>Statically Assigned IP Address</guimenu> )."
msgstr ""

#. Tag: para
#: net_bridge.xml:52
#, no-c-format
msgid "Switch to the <guimenu>Bridged Devices</guimenu> tab. Select the checkbox next to the physical network card or VLAN interface that you want to include as a port inside the bridge matrix."
msgstr ""

#. Tag: para
#: net_bridge.xml:57
#, no-c-format
msgid "Click <guimenu>Next</guimenu> to return to the Network Settings overview, then click <guimenu>OK</guimenu> to save the configuration and restart the network service."
msgstr ""

#. Tag: title
#: net_bridge.xml:64
#, no-c-format
msgid "Manually configure network bridge"
msgstr ""

#. Tag: para
#: net_bridge.xml:65
#, no-c-format
msgid "If you choose to bypass &yast;, you can configure a network bridge manually by modifying the control parameters inside the network directory scripts. In this scenario, we assume a logical bridge interface named <literal>br0</literal> is created to hook to a physical interface named <literal>eth0</literal> ."
msgstr ""

#. Tag: title
#: net_bridge.xml:69
#, no-c-format
msgid "Configuring a bridge with wicked interface declarations"
msgstr ""

#. Tag: para
#: net_bridge.xml:71
#, no-c-format
msgid "Create a new configuration profile for the virtual bridge target at <filename>/etc/sysconfig/network/ifcfg-br0</filename> :"
msgstr ""

#. Tag: screen
#: net_bridge.xml:74
#, no-c-format
msgid "STARTMODE='auto'\n"
      "BOOTPROTO='static'\n"
      "IPADDR='<replaceable>IP_ADDRESS_OF_THE_BRIDGE</replaceable>'\n"
      "BRIDGE='yes'\n"
      "BRIDGE_PORTS='eth0'\n"
      "BRIDGE_STP='off'"
msgstr ""

#. Tag: para
#: net_bridge.xml:82
#, no-c-format
msgid "Modify the properties of the underlying physical network card profile (for example, <filename>/etc/sysconfig/network/ifcfg-eth0</filename> ). Ensure that any existing IP address attributes are deleted, and disable protocol configuration options so that it acts purely as a physical port layer:"
msgstr ""

#. Tag: screen
#: net_bridge.xml:85
#, no-c-format
msgid "STARTMODE='auto'\n"
      "BOOTPROTO='none'"
msgstr ""

#. Tag: para
#: net_bridge.xml:89
#, no-c-format
msgid "If using a static IP topology, map the default gateway explicitly to the bridge network interface using a dedicated routing file profile at <filename>/etc/sysconfig/network/ifroute-br0</filename> :"
msgstr ""

#. Tag: screen
#: net_bridge.xml:92
#, no-c-format
msgid "default <replaceable>GATEWAY_IP_ADDRESS</replaceable> - br0"
msgstr ""

#. Tag: title
#: net_bridge.xml:94
#, no-c-format
msgid "Conflicting router configurations"
msgstr ""

#. Tag: para
#: net_bridge.xml:95
#, no-c-format
msgid "Verify that no obsolete routing statements remain active inside your physical interface script files (such as <filename>ifroute-eth0</filename> ). Failing to remove default paths from physical slave adapters will create structural routing conflict flags inside the kernel."
msgstr ""

#. Tag: para
#: net_bridge.xml:101
#, no-c-format
msgid "Reload the active networking configuration space to enforce the changes:"
msgstr ""

#. Tag: screen
#: net_bridge.xml:104
#, no-c-format
msgid "&prompt.sudo;systemctl restart network"
msgstr ""

